# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Data layer
# This build runs on an in-memory mock database (see src/config/mockdb/) that
# is pre-loaded with realistic demo data every time the server starts.
# No DATABASE_URL / Postgres / Prisma setup is required.
# See backend/docs/DATA_LAYER.md for details and demo login credentials.

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Cloudinary (optional in dev — if left blank, uploads fall back to local disk storage under /backend/uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (optional — if left blank, donations use a dev-mode fake order flow)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
